{
  "expo": {
    "name": "A&T CAPITAL",
    "slug": "at-capital-terminal-277",
    "version": "1.1.8",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "atcapital",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060608"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.thanh.suivitrades",
      "associatedDomains": [],
      "infoPlist": {
        "UIBackgroundModes": ["fetch", "remote-notification"]
      }
    },
    "android": {
      "package": "com.thanh.suivitrades",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#060608"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "atcapital.up.railway.app",
              "pathPrefix": "/app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": true
    },
    "linking": {
      "scheme": "atcapital",
      "prefixes": ["atcapital://", "https://atcapital.up.railway.app"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C9A962",
          "sounds": []
        }
      ],
      "expo-background-fetch"
    ],
    "extra": {
      "eas": {
        "projectId": "suivi-thanh-local"
      }
    }
  }
}
